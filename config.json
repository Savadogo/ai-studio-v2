{
  "studio": {
    "name": "AI Content Studio v2",
    "version": "2.0",
    "hardware": "gpu",
    "default_theme": "relationships"
  },

  "hardware": {
    "device": "cuda",
    "dtype": "float16",
    "vram_gb": 24,
    "enable_xformers": true,
    "enable_vae_slicing": true,
    "enable_model_cpu_offload": false
  },

  "models": {
    "llm": {
      "provider": "ollama",
      "model": "llama3.1:8b",
      "url": "http://localhost:11434",
      "temperature": 0.85,
      "fallback_model": "mistral:7b"
    },
    "image": {
      "base_model": "stabilityai/stable-diffusion-xl-base-1.0",
      "refiner_model": "stabilityai/stable-diffusion-xl-refiner-1.0",
      "use_refiner": true,
      "refiner_switch_at": 0.8,
      "width": 1024,
      "height": 1024,
      "steps": 30,
      "cfg_scale": 7.0,
      "scheduler": "euler_a"
    },
    "animation": {
      "model": "guoyww/animatediff-motion-adapter-v1-5-2",
      "steps": 20,
      "num_frames": 16,
      "fps": 8,
      "motion_scale": 1.0
    },
    "tts": {
      "model": "tts_models/multilingual/multi-dataset/xtts_v2",
      "device": "cuda",
      "speed": 0.95,
      "language": "en"
    },
    "music": {
      "model": "facebook/musicgen-medium",
      "device": "cuda",
      "duration_seconds": 65
    },
    "whisper": {
      "model": "large-v3",
      "device": "cuda",
      "language": "en"
    },
    "lipsync": {
      "model": "wav2lip_gan",
      "enabled": false,
      "checkpoint": "models/wav2lip/wav2lip_gan.pth"
    }
  },

  "video": {
    "fps": 30,
    "youtube": {
      "width": 1920,
      "height": 1080,
      "crf": 16,
      "preset": "slow"
    },
    "shorts": {
      "width": 1080,
      "height": 1920,
      "crf": 18,
      "preset": "fast"
    },
    "tiktok": {
      "width": 1080,
      "height": 1920,
      "crf": 18
    }
  },

  "paths": {
    "output_dir": "output",
    "assets_dir": "assets",
    "models_dir": "/workspace/models",
    "voice_refs_dir": "assets/voice_refs",
    "themes_dir": "themes",
    "logs_dir": "logs"
  },

  "human_review": {
    "enabled": true,
    "slack_webhook": "",
    "auto_approve_after_hours": 8
  },

  "runpod": {
    "api_key": "",
    "preferred_gpu": "NVIDIA GeForce RTX 3090",
    "template_id": "",
    "network_volume_id": "",
    "auto_stop_after_idle_minutes": 30
  }
}
